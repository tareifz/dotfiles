[
  {
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["custom/power"],
    "sway/workspaces": {
      "persistant_workspaces": {
        "1: яЙй: www >": [],
        "2: яДа: term >": [],
        "3: яДб: code >": []
      }
    },
    "sway/window": {
      "format": " тЦСтЦТтЦУ {} тЦУтЦТтЦС"
    },
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
     "custom/power": {
     "format":"яАС  ",
     "on-click":"swaynag -t warning -m 'Power Menu Options' -b 'Logout' 'swaymsg exit' -b 'Suspend' 'systemctl suspend' -b 'shutdown' 'systemctl poweroff'"
     }
  },
  {
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "name": "bottom-bar",
    "height": 28,
    "modules-left": ["custom/cpu-usage","custom/mem-usage"],
    "modules-right": ["pulseaudio", "network", "temperature", "backlight", "battery", "clock", "tray"],
    "tray": {
      // "icon-size": 21,
      "spacing": 10
    },
    "clock": {
      "interval": 1,
      "format": "{:%F <span foreground='yellow'>тЦСтЦТтЦУ</span> %r}",
      "tooltip-format": "{:%Y-%m-%d | %H:%M}",
      "format-alt": "{:%Y-%m-%d}"
    },
    "custom/cpu-usage": {
      "format": "{}  ",
      "interval": 1 , // Remove this if your script is endless and write in loop
      "exec": "fish $HOME/.config/waybar/custom-scripts/cpu-usage.fish 2> /dev/null"
    },
    "custom/mem-usage": {
      "format": "<span foreground='#445678'>тЦСтЦТтЦУ</span> {}",
      "interval": 1 , // Remove this if your script is endless and write in loop
      "exec": "fish $HOME/.config/waybar/custom-scripts/mem-usage.fish 2> /dev/null",
      "tooltip": true
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{temperatureC}┬░C {icon}",
      "format-icons": ["яЭл", "яЛЙ", "яЭй"]
    },
    "backlight": {
      "format": "{percent}% {icon}",
      "format-icons": ["яЖЕ", "яДС"]
    },
    "battery": {
      "states": {
        // "good": 95,
        "warning": 30,
        "critical": 15
      },
      "format": "{capacity}% {icon}",
      "format-charging": "{capacity}% яЧз",
      "format-plugged": "{capacity}% яЗж",
      "format-alt": "{time} {icon}",
      // "format-good": "", // An empty format will hide the module
      // "format-full": "",
      "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "network": {
      "format-wifi": "{essid} ({signalStrength}%) яЗл",
      "format-ethernet": "{ifname}: {ipaddr}/{cidr} яЮЦ",
      "format-linked": "{ifname} (No IP) яЮЦ",
      "format-disconnected": "Disconnected тЪа",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{volume}% {icon} {format_source}",
      "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
      "format-muted": "яЪй {format_source}",
      "format-source": "{volume}% яД░",
      "format-source-muted": "яД▒",
      "format-icons": {
        "headphones": "яАе",
        "handsfree": "яЦР",
        "headset": "яЦР",
        "phone": "яВХ",
        "portable": "яВХ",
        "car": "яЖ╣",
        "default": ["яАж", "яАз", "яАи"]
      },
      "on-click": "pavucontrol"
    }
  }
]
